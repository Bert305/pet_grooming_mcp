# --- Required: Postgres connection used for read-only analytics queries -------
# Copy this from your Supabase project:
#   Project Settings -> Database -> Connection string -> URI
# Use the "Session" pooler URI (port 5432) or the transaction pooler (port 6543).
# Append ?sslmode=require if it is not already present.
DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres?sslmode=require

# --- Optional: Supabase project identifiers (kept for reference/future use) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Optional: tuning knobs (sensible defaults shown) -------------------------
# STATEMENT_TIMEOUT_MS=30000
# MAX_ROW_LIMIT=500
# POOL_MIN_SIZE=1
# POOL_MAX_SIZE=5
